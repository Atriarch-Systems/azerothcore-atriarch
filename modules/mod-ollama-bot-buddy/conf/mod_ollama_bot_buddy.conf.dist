[worldserver]

########################################
# mod-ollama-bot-buddy configuration
# DIRECTOR MODE: the playerbot AI keeps playing the game; the LLM only picks
# high-level directives for the bots listed in OllamaBotControl.BotNames.
# See docs/director-mode.md and docs/seeker-selenwe.md in the repository.
########################################

# OllamaBotControl.Enable
#     Description: Enable or disable the module (master switch).
#     Default:     0 (disabled)
OllamaBotControl.Enable = 0

# OllamaBotControl.Url
#     Description: The URL used to query the Ollama API.
#                  Deployments override via env AC_OLLAMABOTCONTROL_URL.
#     Default:     http://localhost:11434/api/generate
OllamaBotControl.Url = http://localhost:11434/api/generate

# OllamaBotControl.Model
#     Description: The model identifier to be used in the Ollama API request.
#     Default:     llama3.2:1b
OllamaBotControl.Model = gemma4:e4b

# OllamaBotControl.BotNames
#     Description: Comma-separated character names that receive director ticks.
#                  Only these bots consult the LLM; everyone else runs the
#                  normal playerbot AI untouched.
#     Default:     (empty - no director bots)
OllamaBotControl.BotNames =

# OllamaBotControl.TickSeconds
#     Description: Seconds between director decisions per bot (min 10).
#     Default:     45
OllamaBotControl.TickSeconds = 45

# OllamaBotControl.SeekerName
#     Description: Name of the ONE seeker bot (the "find the real player"
#                  experiment, docs/seeker-selenwe.md). Must name an EXISTING
#                  character (e.g. one of the random bots). Empty disables the
#                  seeker. Never run more than one seeker.
#     Default:     (empty)
OllamaBotControl.SeekerName =

# OllamaBotControl.SeekerPersona
#     Description: System prompt/backstory for the seeker.
#     Default:     (built-in wistful night elf huntress persona)
# OllamaBotControl.SeekerPersona =

# OllamaBotControl.ChronicleIntervalMinutes
#     Description: The seeker consolidates her journal into a first-person
#                  memoir chapter ("chronicle") at most this often.
#     Default:     180
OllamaBotControl.ChronicleIntervalMinutes = 180

# OllamaBotControl.ChronicleEventThreshold
#     Description: ...or as soon as this many unconsolidated journal events
#                  have accumulated, whichever comes first.
#     Default:     60
OllamaBotControl.ChronicleEventThreshold = 60

# OllamaBotControl.Debug
#     Description: Verbose logging of directives and LLM replies.
#     Default:     0 (false)
OllamaBotControl.Debug = 0

# OllamaBotControl.EnableBotBuddyAddon
#     Description: Enable or disable sending the bot state to the Bot Buddy addon.
#     Default:     0 (false)
OllamaBotControl.EnableBotBuddyAddon = 0

########################################
# Rebirth cycling (population pyramid)
########################################
# GRADUATION model: cohort bots live their entire journey to max level, and
# only then are reborn at level 1 (Death Knights: their heroic starting
# level). Max level source: the playerbots random-bot ceiling
# (AiPlayerbot.RandomBotMaxLevel) clamped by the world MaxPlayerLevel config.
# Rebirth.PerDay is a RATE CAP, not a quota: if no cohort bot is at max
# level when the interval elapses, nothing happens (a young server sees zero
# rebirths until the first bots cap - expected and correct); steady-state
# turnover self-regulates. Non-cohort bots are long-lived and simply stay
# at cap once they get there.
#
# Cohort partition (deterministic, stable across restarts): random-bot
# accounts (AiPlayerbot.RandomBotAccountPrefix + number) are ordered by their
# numeric suffix; walking that order, accounts are added to the CYCLING
# cohort until their characters total Rebirth.CohortSize. All characters of
# later accounts are long-lived. Characters named in OllamaBotControl.BotNames
# or OllamaBotControl.SeekerName are NEVER reborn, regardless of cohort.
#
# Selection: the online cohort bot with the oldest (or no) previous rebirth
# is chosen -> round-robin over the whole cohort.

# Rebirth.Enable
#     Default: 1 (enabled)
Rebirth.Enable = 1

# Rebirth.PerDay
#     Description: Maximum rebirths per day, spread evenly (8 = at most one
#                  ~every 3h). Only max-level cohort bots ever qualify.
#     Default: 8
Rebirth.PerDay = 8

# Rebirth.CohortSize
#     Description: Target number of characters in the cycling cohort.
#     Default: 500
Rebirth.CohortSize = 500

########################################
# Raid lab (autonomous bot raid experiments)
########################################
# Admin/console commands (SOAP-friendly):
#   .raidlab setup [count]              select, level and gear subjects
#   .raidlab guild [name]               guild the subjects
#   .raidlab start <naxx|eoe|voa|icc>   form the raid and teleport in
#   .raidlab status                     per-subject state + summary
#   .raidlab stop                       disband, teleport out, clear combat
#
# Subjects are drawn ONLY from long-lived random bots (accounts ABOVE the
# Rebirth.CohortSize line) so lab subjects can never be recycled, and never
# include OllamaBotControl.BotNames / SeekerName characters.

# RaidLab.GearScore
#     Description: Gear score ceiling handed to PlayerbotFactory when gearing
#                  subjects (epic quality). The factory compares this against
#                  CalcMixedGearScore = itemLevel * quality multiplier
#                  (epic = 1.4641), so 5000 is far above any WotLK item and
#                  effectively means "no restriction" - deliberately
#                  over-gearing so raid experiments test mechanics, not DPS.
#                  Lower it (e.g. 350) to constrain gear meaningfully.
#     Default:     5000
RaidLab.GearScore = 5000

########################################
# Instance intent layer (scripted progression)
########################################
# The playerbot AI fights well but has no INTENT: teleported into a raid it
# stands still. This engine drives a controlled group along authored route
# data in the characters DB table `mod_instance_route` (seeded for
# Naxxramas/533 - see that base sql for how to derive routes for other maps),
# pausing for combat and resuming afterwards. Movement uses navmesh pathing
# (MotionMaster::MovePoint with generatePath), each member routed
# independently - no follow chains.
#
# Drive it from the raid lab: .raidlab route / go / pause / step <n>.
# Reused in phase 2 for bot group-leaders guiding player groups and for
# guild raid nights.

# Intent.Enable
#     Default: 1
Intent.Enable = 1

# Intent.AdvanceRadius
#     Description: Yards from the waypoint that counts as "arrived"; the step
#                  advances when every living member is within this radius.
#     Default: 15
Intent.AdvanceRadius = 15

# Intent.OutOfCombatSeconds
#     Description: Seconds the group must be out of combat before advancing.
#     Default: 5
Intent.OutOfCombatSeconds = 5

# Intent.StuckTimeout
#     Description: Seconds without advancing before logging "[Intent] stuck at
#                  step N" with every member's distance to the waypoint.
#     Default: 120
Intent.StuckTimeout = 120

########################################
# Guild dungeon progression (Phase 1)
########################################
# A guild's lowest-level eligible cohort forms a group, rallies at a town with
# a flight master, travels to the dungeon, enters together (leader first so all
# members share one instance id), walks an authored route from the WORLD db
# (mod_guild_dungeon_catalog / mod_guild_dungeon_route), and hearths home.
#
# Phase 1 does NOT auto-start runs - drive it with:
#   .guilddungeon cohorts              why each guild can/cannot field a group
#   .guilddungeon start <guildId> <dungeonId>
#   .guilddungeon force <guildId>      ignore level gates (smoke test)
#   .guilddungeon status | abort

GuildDungeon.Enable = 1

# Seconds between cohort evaluations while idle (runs tick every second).
GuildDungeon.TickSeconds = 30

# Lowest level a bot may be drafted at, and how far above the cohort's anchor
# (lowest) level members may be.
GuildDungeon.MinLevel = 15
GuildDungeon.LevelBand = 6

GuildDungeon.MinMembers = 5
GuildDungeon.MaxRunMinutes = 45

# Seconds all members must be dead before a wipe ends the run.
GuildDungeon.WipeGraceSeconds = 60

# Seconds to linger after the last step so asynchronous loot/auto-equip lands.
GuildDungeon.LootGraceSeconds = 20

# Travel flavor: how long to wait for the group to gather at the rally town,
# and how long to walk overland before falling back to a teleport.
GuildDungeon.RallySeconds = 120
GuildDungeon.TravelSeconds = 600

# Realistic travel (docs/playerbot-realistic-travel.md step 1). Both default on;
# either is a kill switch back to the pre-fix behavior if something regresses.
# RealFlightMaster: walk to an actual flightmaster before flying, instead of
# snapping onto the taxi path from wherever the member stands.
# MultiHopTaxi: use the module's own multi-hop taxi graph instead of the core's
# single direct-path lookup, so routes needing a transfer still fly.
GuildDungeon.RealFlightMaster = 1
GuildDungeon.MultiHopTaxi = 1

# Extra time budget added on top of TravelSeconds above to cover the
# walk-to-flightmaster leg RealFlightMaster adds (only applied while it's on).
GuildDungeon.FlightApproachSeconds = 180

# Meeting-stone checkpoint (docs/dungeon-leadership-and-summon.md, section 3b): once bots arrive
# at the entrance (end of Phase::Traveling), the run pauses here for at most this many seconds to
# fetch a non-cohort real player grouped with the run (via the real meeting-stone summon
# mechanic) before proceeding to Phase::Entering. Bots' own arrival is never gated on this -
# only this checkpoint waits, briefly, and only if such a player is present and out of earshot.
GuildDungeon.MeetingStoneWaitSeconds = 90

GuildDungeon.Debug = 1
